<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="spring-19-n-plus-1" name="N+1 problem">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="q1" parent="1" vertex="1" value="Query 1:  SELECT * FROM orders   ->   returns N orders" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="120" y="60" width="650" height="70" as="geometry" />
        </mxCell>
        <mxCell id="loop" parent="1" vertex="1" value="Then, per order (LAZY items accessed in a loop):&#10;SELECT * FROM order_items WHERE order_id = ?   x N" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#FCE8E6;strokeColor=#EA4335;fontColor=#202124;">
          <mxGeometry x="120" y="190" width="650" height="90" as="geometry" />
        </mxCell>
        <mxCell id="total" parent="1" vertex="1" value="= 1 + N queries  (the N+1 selects problem)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#FCE8E6;strokeColor=#EA4335;fontColor=#202124;fontStyle=1;">
          <mxGeometry x="120" y="340" width="650" height="65" as="geometry" />
        </mxCell>
        <mxCell id="e1" parent="1" edge="1" source="q1" target="loop" value="iterate associations" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#232F3E;fontColor=#232F3E;labelBackgroundColor=#FFFFFF;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" parent="1" edge="1" source="loop" target="total" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#232F3E;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" parent="1" vertex="1" value="One query for the parent list, then one extra query per element to load its lazy association." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#5F6368;fontStyle=2;">
          <mxGeometry x="120" y="430" width="650" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
