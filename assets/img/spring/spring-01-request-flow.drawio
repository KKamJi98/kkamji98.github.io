        <mxCell id="tomcat-connector" parent="1" vertex="1" value="Embedded Tomcat&#10;Connector (:8080)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="220" y="140" width="320" height="54" as="geometry" />
        </mxCell>
        <mxCell id="servlet-container" parent="1" vertex="1" value="Servlet Container&#10;(assigns 1 worker thread)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#FEF7E0;strokeColor=#F9AB00;fontColor=#202124;">
          <mxGeometry x="220" y="234" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="filter-chain" parent="1" vertex="1" value="Filter Chain&#10;(security / logging / encoding)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;">
          <mxGeometry x="220" y="338" width="320" height="54" as="geometry" />
        </mxCell>
        <mxCell id="dispatcher" parent="1" vertex="1" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;DispatcherServlet&lt;br&gt;(front controller, mapped to /)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#1A73E8;strokeColor=#1457B0;fontColor=#FFFFFF;fontStyle=1;">
          <mxGeometry x="220" y="436" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="handler" parent="1" vertex="1" value="HandlerMapping &#8594; HandlerAdapter&#10;(find &amp; invoke controller method)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="220" y="540" width="320" height="56" as="geometry" />
        </mxCell>
        <mxCell id="csr" parent="1" vertex="1" value="Controller &#8594; Service &#8594; Repository&#10;(all are Beans, live in heap)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E6F4EA;strokeColor=#34A853;fontColor=#202124;">
          <mxGeometry x="220" y="636" width="320" height="64" as="geometry" />
        </mxCell>
        <mxCell id="converter" parent="1" vertex="1" value="HttpMessageConverter&#10;(return object &#8594; JSON)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#F3E8FD;strokeColor=#A142F4;fontColor=#202124;">
          <mxGeometry x="220" y="740" width="320" height="58" as="geometry" />
        </mxCell>
        <mxCell id="worker-note" parent="1" vertex="1" value="1 worker thread is held&#10;for the whole request&#10;(even while blocking on I/O)" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#B06000;fontStyle=2;">
          <mxGeometry x="14" y="234" width="186" height="64" as="geometry" />
