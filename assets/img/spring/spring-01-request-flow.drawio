<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="spring-01-request-flow" name="HTTP Request Lifecycle">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="760" pageHeight="1000" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="jvm-proc" parent="1" vertex="1" value="JVM Process ( java -jar app.jar )" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;shadow=0;fillColor=#F8F9FA;strokeColor=#9AA0A6;fontColor=#5F6368;fontStyle=1;verticalAlign=top;align=center;dashed=1;spacingTop=8;">
          <mxGeometry x="110" y="96" width="540" height="824" as="geometry" />
        </mxCell>
        <mxCell id="client" parent="1" vertex="1" value="Client" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;">
          <mxGeometry x="290" y="20" width="180" height="44" as="geometry" />
