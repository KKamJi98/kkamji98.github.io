        <mxCell id="s1" parent="1" vertex="1" value="App start (@SpringBootApplication)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;">
          <mxGeometry x="220" y="30" width="320" height="48" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" vertex="1" value="@EnableAutoConfiguration&#10;load AutoConfiguration candidates (AutoConfiguration.imports)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="170" y="126" width="420" height="56" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" vertex="1" value="@Conditional met?&#10;(OnClass / OnMissingBean / OnProperty)" style="rhombus;whiteSpace=wrap;html=1;shadow=0;fillColor=#FEF7E0;strokeColor=#F9AB00;fontColor=#202124;">
          <mxGeometry x="280" y="232" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s4yes" parent="1" vertex="1" value="Register auto-config beans&#10;(embedded Tomcat, DispatcherServlet, ...)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E6F4EA;strokeColor=#34A853;fontColor=#202124;">
          <mxGeometry x="210" y="430" width="340" height="66" as="geometry" />
        </mxCell>
        <mxCell id="s4no" parent="1" vertex="1" value="Skip (backs off)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;">
          <mxGeometry x="580" y="262" width="180" height="60" as="geometry" />
