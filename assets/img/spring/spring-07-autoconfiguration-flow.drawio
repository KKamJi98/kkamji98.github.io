  <diagram id="spring-07-autoconfiguration-flow" name="Auto-configuration Flow">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="560" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
