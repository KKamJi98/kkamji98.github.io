        <mxCell id="note-loop" parent="1" vertex="1" value="repeated for each&#10;AutoConfiguration&#10;candidate" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5F6368;fontStyle=2;">
          <mxGeometry x="40" y="262" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="note-no" parent="1" vertex="1" value="your own bean wins&#10;(non-invasive)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5F6368;fontStyle=2;">
          <mxGeometry x="580" y="330" width="180" height="40" as="geometry" />
