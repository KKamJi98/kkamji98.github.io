<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="spring-02-reading-order-map" name="Curriculum Reading Order">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="660" pageHeight="940" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="s1" parent="1" vertex="1" value="&lt;b&gt;Series 1 - The Path of a Request&lt;/b&gt;&lt;br&gt;1. Big picture: HTTP request flow&lt;br&gt;2. IoC / DI and Beans&lt;br&gt;3. Spring MVC / DispatcherServlet&lt;br&gt;4. Spring Boot autoconfig / fat jar" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;">
          <mxGeometry x="100" y="36" width="460" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s2" parent="1" vertex="1" value="&lt;b&gt;Series 2 - Under the App: JVM and Memory&lt;/b&gt;&lt;br&gt;5. Container exec / buildpack memory&lt;br&gt;6. JVM memory model (heap / off-heap)&lt;br&gt;7. GC basics and G1GC&lt;br&gt;8. GC tuning / JDK version changes" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#FEF7E0;strokeColor=#F9AB00;fontColor=#202124;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;">
          <mxGeometry x="100" y="196" width="460" height="120" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" vertex="1" value="&lt;b&gt;Series 3 - Two Concurrency Paths: MVC vs WebFlux&lt;/b&gt;&lt;br&gt;9. Non-blocking streams / backpressure&lt;br&gt;10. WebFlux / netty event loop&lt;br&gt;11. MVC vs WebFlux: when to use" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;">
          <mxGeometry x="100" y="356" width="460" height="102" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" vertex="1" value="&lt;b&gt;Series 4 - Data Layer&lt;/b&gt;&lt;br&gt;12. JPA / Hibernate / persistence context&lt;br&gt;13. @Transactional / propagation&lt;br&gt;14. N+1 / performance" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#E6F4EA;strokeColor=#34A853;fontColor=#202124;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;">
          <mxGeometry x="100" y="498" width="460" height="102" as="geometry" />
        </mxCell>
        <mxCell id="s5" parent="1" vertex="1" value="&lt;b&gt;Series 5 (optional) - Build / Security&lt;/b&gt;&lt;br&gt;Gradle / Maven, Spring Security" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=0;fillColor=#F3E8FD;strokeColor=#A142F4;fontColor=#202124;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;dashed=1;">
          <mxGeometry x="100" y="640" width="460" height="58" as="geometry" />
        </mxCell>
        <mxCell id="capstone" parent="1" vertex="1" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;&lt;b&gt;Capstone - Real-world Incident Analysis&lt;/b&gt;&lt;br&gt;Boot4 + JDK25 G1GC + netty direct memory + buildpack&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#EA4335;strokeColor=#C5221F;fontColor=#FFFFFF;align=center;verticalAlign=middle;spacingLeft=8;spacingRight=8;fontSize=12;">
