<mxfile host="app.diagrams.net" agent="claude-code" version="24.0.0">
  <diagram id="spring-11-webflux-event-loop" name="WebFlux Event Loop">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="500" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="conns" parent="1" vertex="1" value="Many connections&#10;(A, B, C, D, E, F, ...)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;">
          <mxGeometry x="40" y="190" width="190" height="120" as="geometry" />
        </mxCell>
        <mxCell id="pool" parent="1" vertex="1" value="Netty event loop pool (threads ~ number of CPU cores)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=6;shadow=0;fillColor=#FFFFFF;strokeColor=#1A73E8;fontColor=#1A57B0;fontStyle=1;verticalAlign=top;align=center;dashed=1;spacingTop=8;">
          <mxGeometry x="330" y="80" width="430" height="340" as="geometry" />
        </mxCell>
        <mxCell id="el1" parent="1" vertex="1" value="event-loop-1  ->  serves A, C, E ...  (never blocks)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="360" y="130" width="370" height="56" as="geometry" />
        </mxCell>
        <mxCell id="el2" parent="1" vertex="1" value="event-loop-2  ->  serves B, D, F ...  (never blocks)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="360" y="200" width="370" height="56" as="geometry" />
        </mxCell>
        <mxCell id="elnote" parent="1" vertex="1" value="while one connection's I/O is pending, the thread serves another (non-blocking)" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5F6368;fontStyle=2;">
          <mxGeometry x="360" y="272" width="370" height="40" as="geometry" />
        </mxCell>
        <mxCell id="cmp" parent="1" vertex="1" value="vs thread-per-request (Spring MVC): ~200 threads, each blocked during I/O" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#B06000;fontStyle=2;">
          <mxGeometry x="60" y="452" width="840" height="28" as="geometry" />
        </mxCell>
        <mxCell id="e1" parent="1" edge="1" source="conns" target="el1" value="multiplexed onto few threads" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontColor=#232F3E;strokeColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
