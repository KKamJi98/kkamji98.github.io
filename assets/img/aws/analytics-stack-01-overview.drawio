          <mxGeometry x="20" y="48" width="140" height="55" as="geometry" />
        </mxCell>
        <mxCell id="redshift" value="Redshift Spectrum" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#FFFFFF;strokeColor=#1A73E8;fontColor=#5F6368;dashed=1;" vertex="1" parent="engines_lane">
          <mxGeometry x="20" y="118" width="140" height="55" as="geometry" />
