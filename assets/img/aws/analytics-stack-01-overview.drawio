        <mxCell id="e_user_athena" value="SQL query" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontColor=#232F3E;strokeColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=block;" edge="1" parent="1" source="user" target="athena">
          <mxGeometry relative="1" as="geometry" />
