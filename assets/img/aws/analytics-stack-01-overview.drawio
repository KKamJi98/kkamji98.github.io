        <mxCell id="e_lf_storage" value="data authz" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;dashed=1;fontColor=#232F3E;strokeColor=#232F3E;labelBackgroundColor=#FFFFFF;endArrow=open;" edge="1" parent="1" source="lakeformation" target="s3tables">
