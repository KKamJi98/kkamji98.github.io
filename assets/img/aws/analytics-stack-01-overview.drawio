        <mxCell id="catalog_lane" value="Metadata" style="swimlane;rounded=1;arcSize=6;html=1;fillColor=#F9AB00;fontColor=#202124;swimlaneFillColor=#FEF7E0;strokeColor=#F9AB00;startSize=28;shadow=0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="50" width="180" height="190" as="geometry" />
