<mxfile host="app.diagrams.net">
  <diagram name="AWS Analytics Stack" id="aws-analytics-overview">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="470" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="user" value="Query Author" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="110" height="60" as="geometry" />
        </mxCell>

        <mxCell id="engines_lane" value="Query Engines" style="swimlane;rounded=1;arcSize=6;html=1;fillColor=#1A73E8;fontColor=#FFFFFF;swimlaneFillColor=#E8F0FE;strokeColor=#1A73E8;startSize=28;shadow=0;fontStyle=1;" vertex="1" parent="1">
