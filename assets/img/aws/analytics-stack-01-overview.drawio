        <mxCell id="glue_catalog" value="Glue Data Catalog" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#FFFFFF;strokeColor=#F9AB00;fontColor=#202124;" vertex="1" parent="catalog_lane">
          <mxGeometry x="20" y="60" width="140" height="80" as="geometry" />
        </mxCell>

        <mxCell id="storage_lane" value="Storage" style="swimlane;rounded=1;arcSize=6;html=1;fillColor=#34A853;fontColor=#FFFFFF;swimlaneFillColor=#E6F4EA;strokeColor=#34A853;startSize=28;shadow=0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="690" y="50" width="200" height="190" as="geometry" />
