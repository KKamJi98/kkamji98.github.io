        <mxCell id="s3tables" value="S3 Tables (Iceberg)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#FFFFFF;strokeColor=#34A853;fontColor=#202124;" vertex="1" parent="storage_lane">
          <mxGeometry x="20" y="113" width="160" height="55" as="geometry" />
        </mxCell>

        <mxCell id="perm_lane" value="Permission Gates" style="swimlane;rounded=1;arcSize=6;html=1;fillColor=#EA4335;fontColor=#FFFFFF;swimlaneFillColor=#FCE8E6;strokeColor=#EA4335;startSize=28;shadow=0;fontStyle=1;" vertex="1" parent="1">
