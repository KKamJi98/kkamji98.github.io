        <mxCell id="s2" parent="1" vertex="1" value="2. Glue Data Catalog 조회 (메타데이터)&#10;스키마 + S3 LOCATION + 파티션   [IAM (+ Lake Formation)]" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#FEF7E0;strokeColor=#F9AB00;fontColor=#202124;">
          <mxGeometry x="130" y="230" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s3" parent="1" vertex="1" value="3. S3 / S3 Tables 데이터 스캔 (저장)&#10;파티션 필터로 스캔량(=비용) 축소   [IAM (+ LF for S3 Tables)]" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E6F4EA;strokeColor=#34A853;fontColor=#202124;">
          <mxGeometry x="130" y="340" width="480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="s4" parent="1" vertex="1" value="4. query result location (S3)에 기록 후 반환   [IAM]" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;">
          <mxGeometry x="130" y="450" width="480" height="60" as="geometry" />
        </mxCell>
        <mxCell id="e0" parent="1" edge="1" source="client" target="s1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#232F3E;">
          <mxGeometry relative="1" as="geometry" />
