        <mxCell id="client" parent="1" vertex="1" value="Client (SQL 제출)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;">
          <mxGeometry x="220" y="30" width="300" height="50" as="geometry" />
        </mxCell>
        <mxCell id="s1" parent="1" vertex="1" value="1. StartQueryExecution (Athena, 엔진)&#10;workgroup: 결과 위치 / 스캔 한도 정책   [IAM]" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;">
          <mxGeometry x="130" y="120" width="480" height="70" as="geometry" />
