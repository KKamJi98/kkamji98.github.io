<mxfile host="app.diagrams.net">
  <diagram name="LF Permission Matrix and Timeline" id="lf-permissions">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title1" value="Permission matrix: 2 axes (IAM, Lake Formation) x 3 layers" style="text;html=1;align=left;verticalAlign=middle;fontColor=#202124;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="30" y="18" width="900" height="28" as="geometry" />
        </mxCell>

        <mxCell id="corner" value="Layer" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="54" width="160" height="44" as="geometry" />
        </mxCell>
        <mxCell id="iamhdr" value="IAM (API authz)" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#FAD2CF;strokeColor=#D93025;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="54" width="410" height="44" as="geometry" />
        </mxCell>
        <mxCell id="lfhdr" value="Lake Formation (data authz)" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#EADDFB;strokeColor=#A142F4;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="54" width="410" height="44" as="geometry" />
        </mxCell>

        <mxCell id="lblcat" value="catalog" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="98" width="160" height="78" as="geometry" />
        </mxCell>
        <mxCell id="iamcat" value="glue:GetCatalog / GetCatalogs&#10;+ catalog/s3tablescatalog/{bucket} ARN" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCE8E6;strokeColor=#D93025;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="98" width="410" height="78" as="geometry" />
        </mxCell>
        <mxCell id="lfcat" value="DESCRIBE&#10;on s3tablescatalog/{bucket}" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#F3E8FD;strokeColor=#A142F4;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="98" width="410" height="78" as="geometry" />
        </mxCell>

        <mxCell id="lbldb" value="database" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="176" width="160" height="78" as="geometry" />
        </mxCell>
        <mxCell id="iamdb" value="glue:GetDatabase / GetDatabases&#10;+ database/s3tablescatalog/{bucket}/{db} ARN" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCE8E6;strokeColor=#D93025;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="176" width="410" height="78" as="geometry" />
        </mxCell>
        <mxCell id="lfdb" value="DESCRIBE&#10;on {db}" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#F3E8FD;strokeColor=#A142F4;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="176" width="410" height="78" as="geometry" />
        </mxCell>

        <mxCell id="lbltbl" value="table" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="30" y="254" width="160" height="78" as="geometry" />
        </mxCell>
        <mxCell id="iamtbl" value="glue:GetTable / GetTables&#10;+ table/s3tablescatalog/{bucket}/{db}/* ARN" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#FCE8E6;strokeColor=#D93025;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="190" y="254" width="410" height="78" as="geometry" />
