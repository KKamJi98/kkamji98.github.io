        <mxCell id="lftbl" value="SELECT / DESCRIBE&#10;on table" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#F3E8FD;strokeColor=#A142F4;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="600" y="254" width="410" height="78" as="geometry" />
