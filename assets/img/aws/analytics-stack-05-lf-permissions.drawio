        <mxCell id="gda" value="+ lakeformation:GetDataAccess (IAM) on the query principal  &#8594;  enables credential vending" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=#E8F0FE;strokeColor=#1A73E8;fontColor=#202124;fontSize=11;" vertex="1" parent="1">
