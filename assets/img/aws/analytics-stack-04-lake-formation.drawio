        <mxCell id="principal" value="analytics-workload-role&#10;(principal)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;shadow=0;fillColor=#E8EAED;strokeColor=#9AA0A6;fontColor=#202124;" vertex="1" parent="1">
          <mxGeometry x="30" y="120" width="150" height="70" as="geometry" />
