<mxfile host="app.diagrams.net">
  <diagram name="Lake Formation Gates" id="lake-formation-gates">
    <mxGraphModel dx="900" dy="600" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="980" pageHeight="470" math="0" shadow="0">
      <root>
        <mxCell id="0" />
