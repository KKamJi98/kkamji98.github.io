        <mxCell id="note" parent="1" vertex="1" value="On return: count and 'order' (the reference) pop with the frame. The Order object stays on the heap until GC reclaims it." style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=10;fontColor=#5F6368;fontStyle=2;">
